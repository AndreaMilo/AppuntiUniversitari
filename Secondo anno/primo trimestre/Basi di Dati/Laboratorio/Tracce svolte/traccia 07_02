-- es 1
CREATE DATABASE Biblioteca;
USE Biblioteca;

CREATE TABLE Libro(
    ISBN INT PRIMARY KEY,
    Titolo varchar(100) NOT NULL,
    Autore varchar(50) NOT NULL,
    Genere varchar(70) NOT NULL,
    AnnoPubblicazione YEAR NOT NULL,
    Scaffale char(2) NOT NULL,

    CHECK(Genere IN('Narrativa','Saggistica','thriller','Fantasy','Storico'))
);

CREATE TABLE Iscritto(
    NumTessera INT PRIMARY KEY,
    Nome varchar(50) NOT NULL,
    Cognome varchar(50) NOT NULL,
    CittaResidenza varchar(60) NOT NULL,
    DataIscrizione DATE NOT NULL
);

CREATE TABLE Prestito(
    RefTessera INT NOT NULL,
    RefLibro INT NOT NULL,
    DataPrestito DATE NOT NULL,

    FOREIGN KEY (RefTessera) REFERENCES Iscritto(NumTessera),
    FOREIGN KEY (RefLibro) REFERENCES Libro(ISBN)
);

