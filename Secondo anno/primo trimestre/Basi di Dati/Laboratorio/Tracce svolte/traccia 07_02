-- es 3.1
SELECT L.Titolo,L.Autore,L.Scaffale
FROM Libro L
WHERE L.Genere='Fantasy' AND L.AnnoPubblicazione>2010
ORDER BY L.Autore;

-- es 3.2
SELECT DISTINCT I.Nome,I.Cognome,I.NumTessera
FROM Iscritto I JOIN Prestito P ON I.NumTessera=P.RefTessera JOIN Libro L ON P.RefLibro=L.ISBN
WHERE I.CittaResidenza='Bitonto'AND L.Genere='Saggistica';

-- es 3.3
SELECT L.Titolo, L.ISBN
FROM Libro L
WHERE L.ISBN NOT IN(
    SELECT P.RefLibro
    FROM Prestito P
);

